generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  name               String?
  passwordHash       String?
  avatarUrl          String?
  role               String          @default("USER") // "USER" or "ADMIN"
  plan               String          @default("Free") // "Free" or "StreamVault+"
  status             String          @default("ACTIVE") // "ACTIVE", "BANNED"
  stripeCustomerId   String?         @unique
  lastLogin          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  watchHistory       WatchHistory[]
  watchlist          Watchlist[]
  subscriptions      Subscription[]
}

model Movie {
  id              String         @id @default(uuid())
  title           String
  description     String?
  genre           String?
  releaseYear     String?
  poster          String?
  backdrop        String?
  tmdbId          Int?           @unique
  streamUrl       String?
  trailerUrl      String?
  duration        Int?           // in minutes
  isPremium       Boolean        @default(false)
  contentRating   String?        // e.g. "G", "PG", "PG-13", "R", "NC-17"
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  watchHistory    WatchHistory[]
  watchlist       Watchlist[]
  subtitles       Subtitle[]
}

model Show {
  id              String         @id @default(uuid())
  title           String
  description     String?
  genre           String?
  poster          String?
  backdrop        String?
  tmdbId          Int?           @unique
  releaseYear     String?
  isPremium       Boolean        @default(false)
  contentRating   String?        // e.g. "TV-Y", "TV-G", "TV-PG", "TV-14", "TV-MA"
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  seasons         Season[]
  watchlist       Watchlist[]
}

model Season {
  id              String         @id @default(uuid())
  showId          String
  show            Show           @relation(fields: [showId], references: [id], onDelete: Cascade)
  seasonNumber    Int
  febboxFolderId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  episodes        Episode[]
}

model Episode {
  id              String         @id @default(uuid())
  seasonId        String
  season          Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  episodeNumber   Int
  title           String?
  description     String?
  streamUrl       String?
  duration        Int?
  thumbnail       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  watchHistory    WatchHistory[]
  subtitles       Subtitle[]
}

model WatchHistory {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Can either be a Movie or an Episode
  movieId         String?
  movie           Movie?         @relation(fields: [movieId], references: [id], onDelete: Cascade)
  
  episodeId       String?
  episode         Episode?       @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  
  progress        Int            @default(0) // seconds watched
  timestamp       DateTime       @default(now()) @updatedAt

  @@unique([userId, movieId]) // Ensure 1 entry per movie
  @@unique([userId, episodeId]) // Ensure 1 entry per episode
}

model Watchlist {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  movieId         String?
  movie           Movie?         @relation(fields: [movieId], references: [id], onDelete: Cascade)
  
  showId          String?
  show            Show?          @relation(fields: [showId], references: [id], onDelete: Cascade)
  
  addedDate       DateTime       @default(now())
}

model Subscription {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            String         // "StreamVault+"
  status          String         // "ACTIVE", "EXPIRED", "CANCELLED"
  startDate       DateTime       @default(now())
  endDate         DateTime
  stripeSessionId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Subtitle {
  id              String         @id @default(uuid())
  language        String         // e.g. "English", "Arabic"
  filePath        String         // URL or server path to .srt / .vtt
  
  movieId         String?
  movie           Movie?         @relation(fields: [movieId], references: [id], onDelete: Cascade)
  
  episodeId       String?
  episode         Episode?       @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime       @default(now())
}
